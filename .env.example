# ── TaxLift Frontend (Vite) — Environment Variables ───────────────────────────
# Copy to .env.local for local dev, .env.production for production builds.
# NEVER commit .env.local to source control.

# ── API ────────────────────────────────────────────────────────────────────────
# Points to the TaxLift Express server.
# Leave unset to use the default http://localhost:3001 in development.
VITE_API_URL=http://localhost:3001
# VITE_API_URL=https://api.taxlift.ai    # production

# ── Stripe ─────────────────────────────────────────────────────────────────────
# Publishable key — safe to expose in the browser. Get from:
# https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_LIVE_KEY   # production

# Stripe Price IDs — must match the IDs set in server/.env
VITE_STRIPE_PRICE_STARTER=price_YOUR_STARTER_PRICE_ID
VITE_STRIPE_PRICE_GROWTH=price_YOUR_GROWTH_PRICE_ID

# ── Calendly ───────────────────────────────────────────────────────────────────
# Your Calendly scheduling link. Create a free account at https://calendly.com
# and paste your event URL here.
VITE_CALENDLY_URL=https://calendly.com/taxlift/demo
