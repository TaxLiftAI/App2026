# ── TaxLift API Server — Environment Variables ────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001

# ── Security ───────────────────────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_use_a_long_random_string_in_production
TOKEN_ENCRYPTION_KEY=CHANGE_ME_64_hex_chars_for_aes256_gcm_token_encryption_at_rest
REFERRAL_SECRET=CHANGE_ME_use_a_long_random_string_for_cpa_review_token_signing

# ── GitHub OAuth App ───────────────────────────────────────────────────────────
# Create at: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Authorization callback URL: http://localhost:5173/oauth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Atlassian OAuth 2.0 (3LO) ─────────────────────────────────────────────────
# Create at: https://developer.atlassian.com/console/myapps/ → Create app → OAuth 2.0 (3LO)
# Callback URL: http://localhost:5173/oauth/callback
# Scopes needed: read:jira-work, read:jira-user, offline_access
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
ATLASSIAN_REDIRECT_URI=http://localhost:5173/oauth/callback

# ── Database ───────────────────────────────────────────────────────────────────
# Defaults to /tmp/taxlift.db (persists through restarts but not reboots).
# Override to a permanent path in production.
# DB_PATH=/var/data/taxlift.db

# ── AI Narrative Generation ────────────────────────────────────────────────────
# Required for T661 narrative generation via POST /api/v1/agents/narratives
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Stripe ─────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE
# STRIPE_SECRET_KEY=sk_live_YOUR_LIVE_KEY   # uncomment for production

# Stripe Price IDs — create products in the Stripe Dashboard, then paste IDs here
STRIPE_PRICE_STARTER=price_YOUR_STARTER_PRICE_ID
STRIPE_PRICE_GROWTH=price_YOUR_GROWTH_PRICE_ID

# Stripe webhook secret — get from Dashboard → Webhooks after creating the endpoint
# Endpoint URL: https://your-server.com/api/billing/webhook
# Events to subscribe: checkout.session.completed, customer.subscription.deleted, customer.subscription.updated
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# ── Email / SMTP ───────────────────────────────────────────────────────────────
# Required for scan alerts, drip emails, and CPA notifications.
# Without these, emails fall back to console.log only — nothing is sent.
# Recommended: use Resend (resend.com) with SMTP relay, or any SMTP provider.
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_YOUR_RESEND_API_KEY
EMAIL_FROM=hello@taxlift.ai
ALERT_TO=hello@taxlift.ai
SCAN_ALERT_TO=info@taxlift.ai

# ── Frontend ───────────────────────────────────────────────────────────────────
# Allowed CORS origin in addition to localhost:5173
# FRONTEND_URL=https://app.taxlift.ai
