# Production — Vercel env vars take precedence over this file at build time.
# Keep this in sync with what's set in the Vercel dashboard.
VITE_API_URL=https://app2026-production.up.railway.app

# ── GitHub OAuth App ───────────────────────────────────────────────────────────
# Required for the /scan GitHub connect flow and in-app integrations.
# Create at: https://github.com/settings/developers → OAuth Apps → New OAuth App
#   App name:        TaxLift
#   Homepage URL:    https://www.taxlift.ai
#   Callback URL:    https://www.taxlift.ai/oauth/callback
# Set this in the Vercel dashboard: Settings → Environment Variables
# VITE_GITHUB_CLIENT_ID=Ov23li...
VITE_GITHUB_CLIENT_ID=
